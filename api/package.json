    "@types/multer": "^2.1.0",
    "@types/node": "^25.9.1",
    "@types/pdfkit": "^0.17.6",
    "@types/supertest": "^7.2.0",
    "prisma": "^6.19.3",
    "supertest": "^7.2.2",
    "tsx": "^4.22.3",
